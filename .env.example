# Copy to .env.development and/or .env.production and adjust per environment.
# All client-exposed vars MUST be prefixed with VITE_ (Vite inlines them at build time).
# These defaults use free, key-less public APIs; swap in self-hosted proxies for production.

VITE_APP_ENV=development

# Geocoding / place search (OpenStreetMap Nominatim).
VITE_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Exchange-rate API base (expects /<BASE_CURRENCY> to return { rates: { ... } }).
VITE_EXCHANGE_API_URL=https://api.exchangerate-api.com/v4/latest
